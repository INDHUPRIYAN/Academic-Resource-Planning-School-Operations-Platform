# Copy to .env and fill in. Never commit .env.

# "development" (permissive CORS) or "production" (enforces the guards below).
ENVIRONMENT=development

DATABASE_URL=postgresql://eduflow:eduflow@localhost:5432/eduflow_ai

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Startup fails in production if this is empty or a known default.
SECRET_KEY=change-this-to-a-random-secret

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Required in production. Comma-separated exact origins; "*" is rejected.
# Ignored in development.
CORS_ORIGINS=

GROQ_API_KEY=
